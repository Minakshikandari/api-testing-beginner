      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();\r",
                  "let token = response.token; // Changed from response.data.access_token to response.token\r",
                  "if (token) {\r",
                  "    pm.environment.set(\"auth_token\", token);\r",
                  "    console.log(\"Token:\", token);\r",
                  "} else {\r",
                  "    console.error(\"Access token is not defined.\");\r",
                  "}\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "pub_d79e2635f50451b57e5eabe4a7ec4504407cced4b07db8ff1cacf6ce15dcfff2",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer <key>",
                "type": "text",
                "disabled": true
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"email\": \"eve.holt@reqres.in\",\r\n    \"password\": \"cityslicka\"\r\n}",
              "options": {
